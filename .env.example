# ==============================================
# Biazmark configuration
# ==============================================

# --- Tier (free | basic | pro | enterprise) ---
BIAZMARK_TIER=basic

# --- LLM ---
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Database ---
DATABASE_URL=postgresql+asyncpg://biazmark:biazmark@postgres:5432/biazmark
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==============================================
# OAuth client apps
# Register a developer app on each platform and paste the client id + secret.
# The redirect URI to add on each platform is:
#   {OAUTH_REDIRECT_BASE}/api/oauth/callback/{platform}
# e.g. http://localhost:8000/api/oauth/callback/meta
# ==============================================

OAUTH_REDIRECT_BASE=http://localhost:8000

META_APP_ID=
META_APP_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

X_CLIENT_ID=
X_CLIENT_SECRET=

# ==============================================
# Per-platform fallback tokens (used if no OAuth connection on a business)
# ==============================================

META_ACCESS_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
LINKEDIN_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
X_BEARER_TOKEN=

# ==============================================
# Media generation — the first configured provider is used
# ==============================================

OPENAI_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
MEDIA_STORAGE_DIR=./data/media
MEDIA_PUBLIC_BASE=http://localhost:8000/media

# ==============================================
# Email + blog
# ==============================================

RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=

WORDPRESS_BASE=
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# ==============================================
# Research data sources (optional, enables deeper research tiers)
# ==============================================

SERPAPI_KEY=
SIMILARWEB_API_KEY=

# ==============================================
# Observability
# ==============================================

LOG_LEVEL=INFO
SENTRY_DSN=
