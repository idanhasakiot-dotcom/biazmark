# Copy these into Vercel → Project Settings → Environment Variables → Production.
# Only BIAZMARK_BACKEND_URL is strictly required for the Vercel deploy to proxy
# API requests to your live FastAPI backend.

# The public URL of your deployed backend (Fly / Railway / Render / ...).
# Next.js rewrites /api/* and /media/* through to this origin on the server side,
# so browsers never talk to it directly — no CORS to configure.
BIAZMARK_BACKEND_URL=https://biazmark-backend.fly.dev

# Optional: force the browser-side API base. Leave blank to use same-origin
# (recommended — safer, avoids CORS, works with Next rewrites above).
NEXT_PUBLIC_API_URL=
